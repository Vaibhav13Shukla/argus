# Stream (get from https://dashboard.getstream.io)
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret

# OpenRouter — used for Llama LLM (get from https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key

# ElevenLabs — text-to-speech (get from https://elevenlabs.io)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Deepgram — speech-to-text (get from https://deepgram.com)
DEEPGRAM_API_KEY=your_deepgram_api_key